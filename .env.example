LOG_LEVEL=INFO
LOG_FILE=logs/bee_bug_hunter.jsonl

LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://localhost:11434

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=demo

# Global fallback docker host every flow uses (blank = local daemon). A flow can still
# set its own docker_host: override in manifest.yaml to target a different host --
# see that file's header comment for the tcp://host:2376 / ssh://user@host syntax.
BEE_DEFAULT_DOCKER_HOST=
